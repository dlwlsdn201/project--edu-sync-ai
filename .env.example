EXPO_PUBLIC_SUPABASE_URL=your_supabase_project_url
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
EXPO_PUBLIC_KAKAO_NATIVE_APP_KEY=your_kakao_native_app_key
EXPO_PUBLIC_GEMINI_API_KEY=your_gemini_api_key
# 선택: 기본 gemini-2.5-flash. 429가 잦으면 flash-lite 권장
# EXPO_PUBLIC_GEMINI_MODEL=gemini-2.5-flash-lite
# 주 모델 실패 시 자동 시도할 폴백 (기본: gemini-2.5-flash-lite)
# EXPO_PUBLIC_GEMINI_FALLBACK_MODEL=gemini-2.5-flash-lite
